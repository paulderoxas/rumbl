  <div
    id="create-room-modal"
    phx-hook=".RoomModal"
    class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center z-50"
    style="z-index: 50"
  >
    
    <%= if !@room do %>
      <div class="rounded-3xl p-8 bg-white/[0.05] border border-white/[0.1] backdrop-blur-md max-w-sm w-full mx-4 shadow-2xl">
        <h2 class="text-2xl font-bold text-slate-50 mb-4">Watch Together</h2>

        <p class="text-slate-300 mb-6">
          Create a room to watch this video together with others. You'll get a unique code to share.
        </p>

        <div class="flex gap-3">
          <button
            phx-click="create_room"
            class="flex-1 px-6 py-3 bg-gradient-to-r from-indigo-500 to-violet-500 hover:from-indigo-600 hover:to-violet-600 text-white rounded-lg transition-all duration-200 font-medium"
          >
            Create Room
          </button>
          <button
            phx-click="hide-create-room-modal"
            class="flex-1 px-6 py-3 bg-white/[0.05] hover:bg-white/[0.1] border border-white/[0.1] text-slate-50 rounded-lg transition-colors font-medium"
          >
            Cancel
          </button>
        </div>
      </div>
    <% else %>
      
      <div class="rounded-3xl p-8 bg-white/[0.05] border border-white/[0.1] backdrop-blur-md max-w-sm w-full mx-4 shadow-2xl">
        <h2 class="text-2xl font-bold text-slate-50 mb-4">Room Active</h2>

        <div class="mb-6 p-4 rounded-xl bg-white/[0.03] border border-white/[0.1]">
          <p class="text-xs font-semibold text-slate-400 mb-2">Room Code</p>
          <p class="text-2xl font-mono font-bold text-indigo-400 mb-3">{@room.code}</p>
          <p class="text-xs text-slate-300 mb-3">Share this code with others to join</p>
          <button
            id="copy-room-code-btn"
            type="button"
            class="w-full px-3 py-2 text-xs bg-indigo-500 hover:bg-indigo-600 text-white rounded-lg transition-colors font-medium"
          >
            Copy Code
          </button>
        </div>

        <div class="mb-6">
          <p class="text-xs font-semibold text-slate-400 mb-3">In Room</p>
          <div class="flex items-center gap-3">
            
            <div class="relative group">
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-indigo-400 to-violet-500 flex items-center justify-center text-sm font-bold text-white">
                {String.first(@room.host.username |> String.upcase())}
              </div>
              <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-2 py-1 bg-slate-950 border border-white/[0.1] rounded text-xs text-slate-50 whitespace-nowrap hidden group-hover:block z-10">
                {@room.host.username} (Host)
              </div>
            </div>
            <div class="flex-1">
              <p class="text-sm font-medium text-slate-50">{@room.host.username}</p>
              <p class="text-xs text-slate-400">Host</p>
            </div>
          </div>
        </div>

        <div class="flex gap-3">
          <button
            phx-click="hide-create-room-modal"
            class="flex-1 px-6 py-3 bg-white/[0.05] hover:bg-white/[0.1] border border-white/[0.1] text-slate-50 rounded-lg transition-colors font-medium"
          >
            Close
          </button>
          <button
            phx-click="close_room"
            class="flex-1 px-6 py-3 bg-red-500/20 hover:bg-red-500/30 border border-red-500/30 text-red-400 rounded-lg transition-colors font-medium"
          >
            End Room
          </button>
        </div>
      </div>
    <% end %>
  </div>

  <script :type={Phoenix.LiveView.ColocatedHook} name=".RoomModal">
    export default {
      setupCopyButton() {
        const copyBtn = this.el.querySelector("#copy-room-code-btn");
        if (copyBtn) {
          // Remove existing listeners by cloning
          const newBtn = copyBtn.cloneNode(true);
          copyBtn.replaceWith(newBtn);

          newBtn.addEventListener("click", (e) => {
            e.preventDefault();
            // Find the room code from the modal
            const codeElement = this.el.querySelector(".text-2xl.font-mono.font-bold");
            const code = codeElement ? codeElement.textContent.trim() : "";

            if (code) {
              navigator.clipboard.writeText(code).then(() => {
                const originalText = newBtn.textContent;
                newBtn.textContent = "✓ Copied!";
                newBtn.classList.add("bg-green-500", "hover:bg-green-600");
                newBtn.classList.remove("bg-indigo-500", "hover:bg-indigo-600");
                setTimeout(() => {
                  newBtn.textContent = originalText;
                  newBtn.classList.remove("bg-green-500", "hover:bg-green-600");
                  newBtn.classList.add("bg-indigo-500", "hover:bg-indigo-600");
                }, 2000);
              }).catch(() => {
                alert("Failed to copy code");
              });
            }
          });
        }
      },

      mounted() {
        this.el = document.getElementById("create-room-modal");
        this.setupCopyButton();

        // Show modal
        this.handleEvent("show-create-room-modal", () => {
          this.el.classList.remove("hidden");
        });

        // Hide modal
        this.handleEvent("hide-create-room-modal", () => {
          this.el.classList.add("hidden");
        });

        // Room created - refresh modal content
        this.handleEvent("room-created", () => {
          // Modal stays open to show room code
        });

        // Close on background click
        this.el.addEventListener("click", (e) => {
          if (e.target === this.el) {
            this.el.classList.add("hidden");
          }
        });

        // Close on escape key
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && !this.el.classList.contains("hidden")) {
            this.el.classList.add("hidden");
          }
        });
      },

      updated() {
        // Re-setup copy button after content updates
        this.setupCopyButton();
      }
    }
  </script>
</div>
